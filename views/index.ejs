<%- include('partials/header') %>

<h1 class="text-3xl font-bold mb-6">Messages</h1>

<% if (messages && messages.length > 0) { %>
  <div class="space-y-4">
    <% messages.forEach(message => { %>
      <div class="card-bg p-6 rounded-xl shadow-sm">
        <h2 class="text-xl font-semibold mb-2"><%= message.title %></h2>
        <p class="text-gray-700 mb-4"><%= message.text %></p>
        
        <div class="flex justify-between items-center text-sm text-gray-500">
          <% if (locals.currentUser && locals.currentUser.membership_status) { %>
            <span>By <%= message.first_name %> <%= message.last_name %></span>
            <span><%= new Date(message.timestamp).toLocaleString() %></span>
          <% } else { %>
            <span>By Anonymous</span>
            <span>Date Hidden</span>
          <% } %>
        </div>

        <% if (locals.currentUser && locals.currentUser.is_admin) { %>
          <form action="/delete-message/<%= message.id %>" method="POST" class="mt-4">
            <button type="submit" class="bg-red-500 text-white px-3 py-1 rounded hover:bg-red-600 text-sm">Delete</button>
          </form>
        <% } %>
      </div>
    <% }) %>
  </div>
<% } else { %>
  <p class="text-gray-600">No messages yet. Be the first to post!</p>
<% } %>

</main>
</body>
</html>
