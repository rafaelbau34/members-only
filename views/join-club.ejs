<%- include('partials/header') %>

<div class="max-w-md mx-auto card-alt-bg p-8 rounded-xl shadow-sm">
  <h1 class="text-2xl font-bold mb-6 text-center">Join the Club</h1>
  
  <% if (locals.error) { %>
    <p class="mb-4 text-red-500 text-sm text-center"><%= error %></p>
  <% } %>

  <form action="/join-club" method="POST" class="space-y-4">
    <div>
      <label class="block text-sm font-medium text-gray-700">Secret Passcode</label>
      <input type="password" name="passcode" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm border p-2">
    </div>
    <button type="submit" class="w-full bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700">Submit</button>
  </form>
</div>

</main>
</body>
</html>
