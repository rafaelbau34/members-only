<%- include('partials/header') %>

<div class="max-w-md mx-auto bg-white p-8 rounded-xl shadow-sm">
  <h1 class="text-2xl font-bold mb-6 text-center">Log In</h1>
  
  <form action="/login" method="POST" class="space-y-4">
    <div>
      <label class="block text-sm font-medium text-gray-700">Email</label>
      <input type="email" name="username" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm border p-2">
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700">Password</label>
      <input type="password" name="password" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm border p-2">
    </div>
    <button type="submit" class="w-full bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700">Log In</button>
  </form>
</div>

</main>
</body>
</html>
